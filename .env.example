# =============================================================================
# Quiver — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in all values.
# Each variable is documented with where to find its value.

# -----------------------------------------------------------------------------
# Database (Supabase Postgres recommended, any Postgres supported)
# -----------------------------------------------------------------------------

# Postgres connection string (pooled).
# Supabase: Settings → Database → Connection string → URI (use connection pooler)
DATABASE_URL=

# Direct connection URL for Prisma migrations (non-pooled).
# Supabase: Settings → Database → Connection string → URI (use direct connection)
DIRECT_URL=

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------

# Your Supabase project URL.
# Supabase: Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous (public) key — safe for client-side use.
# Supabase: Settings → API → Project API keys → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — server-side only, never expose to client.
# Supabase: Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Anthropic
# -----------------------------------------------------------------------------

# Your Anthropic API key — used for all AI sessions.
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

# Your deployment URL (e.g. https://quiver.yourteam.com or http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000
